import cv2
import numpy as np
import tkinter as tk
from tkinter import filedialog
from PIL import Image, ImageTk
import math

class InspectionApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Industrial Machine Vision - Spatial Density Outlier Detection")
        self.root.geometry("1450x850")
        
        self.current_image = None
        self.processed_image = None
        
        self.setup_ui()
        
    def setup_ui(self):
        # --- LEFT PANEL: CONTROLS ---
        control_frame = tk.Frame(self.root, width=380, bg="#f0f0f0", padx=10, pady=10)
        control_frame.pack(side=tk.LEFT, fill=tk.Y)
        
        tk.Label(control_frame, text="1. Input Source", font=("Arial", 11, "bold"), bg="#f0f0f0").pack(pady=(0, 5))
        tk.Button(control_frame, text="Upload Image", command=self.upload_image, width=20).pack(pady=2)
        tk.Button(control_frame, text="Capture via Camera", command=self.capture_camera, width=20).pack(pady=2)
        
        tk.Label(control_frame, text="2. Edge Detection Method", font=("Arial", 11, "bold"), bg="#f0f0f0").pack(pady=(15, 5))
        self.edge_method = tk.StringVar(value="Canny")
        tk.Radiobutton(control_frame, text="Canny Edge", variable=self.edge_method, value="Canny", bg="#f0f0f0").pack()
        tk.Radiobutton(control_frame, text="Adaptive Threshold", variable=self.edge_method, value="Adaptive", bg="#f0f0f0").pack()
        
        tk.Label(control_frame, text="3. Illumination & Filter Tuning", font=("Arial", 11, "bold"), bg="#f0f0f0").pack(pady=(15, 5))
        
        # CLAHE Grid Size
        self.clahe_var = tk.IntVar(value=8)
        tk.Label(control_frame, text="CLAHE Grid Size (8 to 16)", bg="#f0f0f0").pack()
        tk.Scale(control_frame, variable=self.clahe_var, from_=4, to=32, resolution=4, orient=tk.HORIZONTAL).pack()

        # Laplacian K-Size
        self.ksize_var = tk.IntVar(value=3)
        tk.Label(control_frame, text="Raw Laplacian K-Size (1, 3, 5, 7)", bg="#f0f0f0").pack()
        tk.Scale(control_frame, variable=self.ksize_var, from_=1, to=7, resolution=2, orient=tk.HORIZONTAL).pack()
        
        # Laplacian Threshold
        self.thresh_var = tk.IntVar(value=40)
        tk.Label(control_frame, text="Laplacian Intensity Threshold", bg="#f0f0f0").pack()
        tk.Scale(control_frame, variable=self.thresh_var, from_=10, to=200, orient=tk.HORIZONTAL).pack()
        
        tk.Label(control_frame, text="4. Spatial Density (Outlier Logic)", font=("Arial", 11, "bold"), bg="#f0f0f0").pack(pady=(15, 5))

        # Spatial Radius (Simulating the 1x1 cm area)
        self.radius_var = tk.IntVar(value=50)
        tk.Label(control_frame, text="Neighborhood Radius (Pixels)", bg="#f0f0f0").pack()
        tk.Scale(control_frame, variable=self.radius_var, from_=10, to=200, orient=tk.HORIZONTAL).pack()
        
        # Max Neighbors allowed in that radius
        self.neighbors_var = tk.IntVar(value=2)
        tk.Label(control_frame, text="Max Allowed Neighbors (Noise Filter)", bg="#f0f0f0").pack()
        tk.Scale(control_frame, variable=self.neighbors_var, from_=0, to=10, orient=tk.HORIZONTAL).pack()

        tk.Button(control_frame, text="RUN PIPELINE", command=self.run_pipeline, bg="green", fg="white", font=("Arial", 12, "bold"), width=20).pack(pady=20)
        
        # --- MIDDLE PANEL: IMAGE DISPLAY ---
        display_frame = tk.Frame(self.root, bg="black")
        display_frame.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        
        self.image_label = tk.Label(display_frame, text="Upload or Capture an image to begin", fg="white", bg="black", font=("Arial", 14))
        self.image_label.pack(expand=True)
        
        # --- RIGHT PANEL: DOCUMENTATION ---
        doc_frame = tk.Frame(self.root, width=250, bg="#e8e8e8", padx=10, pady=10)
        doc_frame.pack(side=tk.RIGHT, fill=tk.Y)
        
        tk.Label(doc_frame, text="How Parameters Affect Output", font=("Arial", 11, "bold"), bg="#e8e8e8").pack(pady=(0, 10))
        
        docs = """1. CLAHE Grid Size:
Flattens lighting locally. 
• 8x8 is highly localized.
• 16x16 preserves slightly larger gradients.

2. Laplacian K-Size:
• K=1: Finds 1-pixel micro variations.
• K=3: Best for standard dents.

3. Neighborhood Radius:
Think of this as the "1x1 cm area" you mentioned. It creates a virtual circle around every detected point.

4. Max Allowed Neighbors:
This solves the repeating glare issue!
• If a point has MORE neighbors than this limit in its radius, the algorithm knows it is repeating light/texture noise and ignores it.
• If it has FEWER neighbors, it is an isolated outlier (a real dent) and is popped as RED.
"""
        doc_text = tk.Text(doc_frame, wrap=tk.WORD, bg="#e8e8e8", borderwidth=0, font=("Arial", 10))
        doc_text.insert(tk.END, docs)
        doc_text.config(state=tk.DISABLED)
        doc_text.pack(fill=tk.BOTH, expand=True)

    def upload_image(self):
        file_path = filedialog.askopenfilename(filetypes=[("Images", "*.jpg *.jpeg *.png")])
        if file_path:
            self.current_image = cv2.imread(file_path)
            self.display_image(self.current_image)
            
    def capture_camera(self):
        cap = cv2.VideoCapture(0)
        ret, frame = cap.read()
        if ret:
            self.current_image = frame
            self.display_image(self.current_image)
        cap.release()

    def get_contour_centroids(self, contours):
        """Extracts the center (x,y) point of each contour to calculate distances."""
        candidates = []
        for c in contours:
            area = cv2.contourArea(c)
            if area > 1: # Ignore literal single-pixel mathematical anomalies
                M = cv2.moments(c)
                if M["m00"] != 0:
                    cx = int(M["m10"] / M["m00"])
                    cy = int(M["m01"] / M["m00"])
                    candidates.append({"contour": c, "center": (cx, cy)})
        return candidates

    def run_pipeline(self):
        if self.current_image is None:
            return
            
        img = self.current_image.copy()
        gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
        
        # ==========================================
        # STEP 1: LOCAL LIGHTING ADJUSTMENT (CLAHE)
        # ==========================================
        grid_size = self.clahe_var.get()
        clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(grid_size, grid_size))
        gray_equalized = clahe.apply(gray)
        
        # Background Separation (Using Otsu on original gray to find phone chassis)
        _, bg_thresh = cv2.threshold(gray, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)
        bg_mask = cv2.morphologyEx(bg_thresh, cv2.MORPH_CLOSE, cv2.getStructuringElement(cv2.MORPH_RECT, (15, 15)))
        
        # ==========================================
        # STEP 2: ROI & FINE LINE BORDERS
        # ==========================================
        if self.edge_method.get() == "Canny":
            edges = cv2.Canny(gray_equalized, 30, 100)
        else:
            edges = cv2.adaptiveThreshold(gray_equalized, 255, cv2.ADAPTIVE_THRESH_GAUSSIAN_C, cv2.THRESH_BINARY_INV, 11, 2)
            
        edges_inside_phone = cv2.bitwise_and(edges, edges, mask=bg_mask)
        contours, _ = cv2.findContours(edges_inside_phone, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        
        roi_mask = np.zeros_like(gray)
        output_img = img.copy()
        
        # Draw Fine Blue Lines mapping camera/chassis
        for c in contours:
            if cv2.contourArea(c) > 1000:
                cv2.drawContours(roi_mask, [c], -1, 255, thickness=cv2.FILLED)
                cv2.drawContours(output_img, [c], -1, (255, 0, 0), 1) 
                
        interior_mask = cv2.erode(roi_mask, cv2.getStructuringElement(cv2.MORPH_RECT, (5, 5)), iterations=1)
        edge_mask = cv2.bitwise_xor(roi_mask, interior_mask)

        # ==========================================
        # STEP 3: RAW LAPLACIAN
        # ==========================================
        ksize = self.ksize_var.get()
        if ksize % 2 == 0: ksize += 1 
        
        laplacian = cv2.Laplacian(gray_equalized, cv2.CV_64F, ksize=ksize)
        lap_abs = cv2.convertScaleAbs(laplacian)
        
        threshold_val = self.thresh_var.get()
        
        # Extract binary hits for both Interior and Edge
        lap_interior = cv2.bitwise_and(lap_abs, lap_abs, mask=interior_mask)
        _, bin_interior = cv2.threshold(lap_interior, threshold_val, 255, cv2.THRESH_BINARY)
        int_contours, _ = cv2.findContours(bin_interior, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        
        lap_edge = cv2.bitwise_and(lap_abs, lap_abs, mask=edge_mask)
        _, bin_edge = cv2.threshold(lap_edge, threshold_val, 255, cv2.THRESH_BINARY)
        edge_contours, _ = cv2.findContours(bin_edge, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

        # ==========================================
        # STEP 4: SPATIAL DENSITY OUTLIER FILTERING
        # ==========================================
        search_radius = self.radius_var.get()
        max_neighbors = self.neighbors_var.get()
        
        # Get centroids of all detected hits
        interior_candidates = self.get_contour_centroids(int_contours)
        edge_candidates = self.get_contour_centroids(edge_contours)
        
        # Filter Interior Candidates (Solid Red Blobs)
        for i, target in enumerate(interior_candidates):
            tx, ty = target["center"]
            neighbors = 0
            # Check distance against all other interior hits
            for j, other in enumerate(interior_candidates):
                if i != j:
                    ox, oy = other["center"]
                    distance = math.hypot(tx - ox, ty - oy)
                    if distance <= search_radius:
                        neighbors += 1
            
            # If it has fewer neighbors than the limit, it's a true, isolated anomaly
            if neighbors <= max_neighbors:
                cv2.drawContours(output_img, [target["contour"]], -1, (0, 0, 255), thickness=-1)

        # Filter Edge Candidates (Thick Red Circles)
        for i, target in enumerate(edge_candidates):
            tx, ty = target["center"]
            neighbors = 0
            for j, other in enumerate(edge_candidates):
                if i != j:
                    ox, oy = other["center"]
                    distance = math.hypot(tx - ox, ty - oy)
                    if distance <= search_radius:
                        neighbors += 1
            
            if neighbors <= max_neighbors:
                cv2.circle(output_img, (tx, ty), 4, (0, 0, 255), 2)

        self.display_image(output_img)

    def display_image(self, cv_img):
        h, w = cv_img.shape[:2]
        max_height = 700
        if h > max_height:
            scale = max_height / h
            cv_img = cv2.resize(cv_img, (int(w * scale), int(h * scale)))
            
        rgb_image = cv2.cvtColor(cv_img, cv2.COLOR_BGR2RGB)
        pil_image = Image.fromarray(rgb_image)
        tk_image = ImageTk.PhotoImage(image=pil_image)
        
        self.image_label.config(image=tk_image, text="")
        self.image_label.image = tk_image 

if __name__ == "__main__":
    root = tk.Tk()
    app = InspectionApp(root)
    root.mainloop()
