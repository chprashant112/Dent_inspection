import cv2
import numpy as np
import tkinter as tk
from tkinter import filedialog
from PIL import Image, ImageTk
import math

class InspectionApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Industrial Machine Vision - Multi-Engine Sandbox")
        self.root.geometry("1450x850")
        
        self.current_image = None
        self.processed_image = None
        
        self.setup_ui()
        
    def setup_ui(self):
        # --- LEFT PANEL: CONTROLS ---
        control_frame = tk.Frame(self.root, width=380, bg="#f0f0f0", padx=10, pady=10)
        control_frame.pack(side=tk.LEFT, fill=tk.Y)
        
        tk.Label(control_frame, text="1. Input Source", font=("Arial", 11, "bold"), bg="#f0f0f0").pack(pady=(0, 5))
        tk.Button(control_frame, text="Upload Image", command=self.upload_image, width=20).pack(pady=2)
        tk.Button(control_frame, text="Capture via Camera", command=self.capture_camera, width=20).pack(pady=2)
        
        tk.Label(control_frame, text="2. Detection Engine", font=("Arial", 11, "bold"), bg="#f0f0f0").pack(pady=(15, 5))
        
        self.engine_var = tk.StringVar(value="Raw Laplacian + Density (Sharp Dents)")
        engines = [
            "Raw Laplacian + Density (Sharp Dents)",
            "Gabor Filter Bank (Thin Scratches)",
            "Local Variance (Smudges & Sludge)",
            "Local Binary Patterns (Texture Shifts)",
            "FFT High-Pass (Repeating Noise Removal)"
        ]
        tk.OptionMenu(control_frame, self.engine_var, *engines).pack(fill=tk.X, padx=10)
        
        tk.Label(control_frame, text="3. Tuning Parameters", font=("Arial", 11, "bold"), bg="#f0f0f0").pack(pady=(15, 5))
        
        self.clahe_var = tk.IntVar(value=8)
        tk.Label(control_frame, text="CLAHE Grid Size (Light Flattening)", bg="#f0f0f0").pack()
        tk.Scale(control_frame, variable=self.clahe_var, from_=4, to=32, resolution=4, orient=tk.HORIZONTAL).pack()

        self.thresh_var = tk.IntVar(value=40)
        tk.Label(control_frame, text="Global Intensity/Response Threshold", bg="#f0f0f0").pack()
        tk.Scale(control_frame, variable=self.thresh_var, from_=5, to=200, orient=tk.HORIZONTAL).pack()
        
        tk.Label(control_frame, text="4. Density Filter (Laplacian/Gabor Only)", font=("Arial", 11, "bold"), bg="#f0f0f0").pack(pady=(15, 5))

        self.radius_var = tk.IntVar(value=50)
        tk.Label(control_frame, text="Neighborhood Radius (Pixels)", bg="#f0f0f0").pack()
        tk.Scale(control_frame, variable=self.radius_var, from_=10, to=200, orient=tk.HORIZONTAL).pack()
        
        self.neighbors_var = tk.IntVar(value=2)
        tk.Label(control_frame, text="Max Allowed Neighbors", bg="#f0f0f0").pack()
        tk.Scale(control_frame, variable=self.neighbors_var, from_=0, to=10, orient=tk.HORIZONTAL).pack()

        tk.Button(control_frame, text="RUN PIPELINE", command=self.run_pipeline, bg="green", fg="white", font=("Arial", 12, "bold"), width=20).pack(pady=20)
        
        # --- MIDDLE PANEL: IMAGE DISPLAY ---
        display_frame = tk.Frame(self.root, bg="black")
        display_frame.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        
        self.image_label = tk.Label(display_frame, text="Upload or Capture an image to begin", fg="white", bg="black", font=("Arial", 14))
        self.image_label.pack(expand=True)
        
        # --- RIGHT PANEL: DOCUMENTATION ---
        doc_frame = tk.Frame(self.root, width=250, bg="#e8e8e8", padx=10, pady=10)
        doc_frame.pack(side=tk.RIGHT, fill=tk.Y)
        
        tk.Label(doc_frame, text="Engine Documentation", font=("Arial", 11, "bold"), bg="#e8e8e8").pack(pady=(0, 10))
        
        docs = """1. Raw Laplacian:
Finds sharp intensity jumps. Density filter removes repeated glare.

2. Gabor Filter Bank:
Sweeps 4 angles (0°, 45°, 90°, 135°) to find faint directional scratches that Laplacian misses.

3. Local Variance:
Finds soft defects (smudges/grease). Slides an 11x11 window; if pixels fade softly instead of jumping sharply, variance spikes. (Ignores Density Filter)

4. Local Binary Patterns (LBP):
Calculates mathematical texture. Spikes when surface finish changes (e.g. glossy spot on matte glass).

5. FFT High-Pass:
Converts image to frequencies. Deletes low-frequency rolling light variations, leaving only harsh anomalies.
"""
        doc_text = tk.Text(doc_frame, wrap=tk.WORD, bg="#e8e8e8", borderwidth=0, font=("Arial", 10))
